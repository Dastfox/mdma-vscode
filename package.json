{
    "name": "mdma-language",
    "displayName": "MDMA — Markdown Mapped",
    "description": "Syntax highlighting, linting, and formatting for .mdma (Markdown Mapped) template files",
    "version": "0.2.0",
    "publisher": "dast-fox",
    "author": "Théo Renard",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Dastfox/mdma-vscode.git"
    },
    "bugs": "https://github.com/Dastfox/mdma-vscode/issues",
    "homepage": "https://dastfox.github.io/mdma/",
    "icon": "./icons/icon.png",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters"
    ],
    "main": "./dist/extension.js",
    "scripts": {
        "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node16",
        "watch": "npm run compile -- --watch",
        "typecheck": "tsc --noEmit",
        "vscode:prepublish": "npm run compile"
    },
    "dependencies": {
        "markdownlint": "^0.41.0",
        "typescript-mdma": "^0.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.74.0",
        "esbuild": "^0.28.1",
        "typescript": "^5.5.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "mdma",
                "aliases": [
                    "Markdown Mapped",
                    "mdma"
                ],
                "extensions": [
                    ".mdma"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/mdma-file-light.svg",
                    "dark": "./icons/mdma-file-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "mdma",
                "scopeName": "source.mdma",
                "path": "./syntaxes/mdma.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "mdma",
                "path": "./snippets/mdma.json"
            }
        ]
    }
}
