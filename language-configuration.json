{
    "comments": {
        "blockComment": ["{#", "#}"]
    },
    "brackets": [
        ["{%", "%}"],
        ["{{", "}}"],
        ["{#", "#}"],
        ["<", ">"]
    ],
    "autoClosingPairs": [
        { "open": "{{", "close": " }}" },
        { "open": "{%", "close": " %}" },
        { "open": "{#", "close": " #}" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "`", "close": "`" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" }
    ],
    "surroundingPairs": [
        ["{{", "}}"],
        ["{%", "%}"],
        ["{#", "#}"],
        ["\"", "\""],
        ["'", "'"],
        ["`", "`"],
        ["*", "*"],
        ["_", "_"],
        ["[", "]"],
        ["(", ")"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "\\{%[-]?\\s*(if|for|elif|else)\\b.*%\\}",
        "decreaseIndentPattern": "\\{%[-]?\\s*(endif|endfor|elif|else)\\b.*%\\}"
    },
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.]*"
}
